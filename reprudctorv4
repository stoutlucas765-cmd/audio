class _MainPlayerScreenState extends State<MainPlayerScreen> {
  List<String> _playlist = [];
  int _currentIndex = -1;
  bool _isPlaying = false;
  bool _isShuffle = false;
  List<int> _shuffledIndices = [];

  Duration _duration = Duration.zero;
  Duration _position = Duration.zero;

  @override
  void initState() {
    super.initState();
    _initAudioListeners();
    _loadSavedPlaylist();
  }

  void _initAudioListeners() {
    _audioHandler.playerInstance.onDurationChanged.listen(
      (d) => setState(() => _duration = d),
    );

    // CORRECCIÓN CLAVE: Filtra y frena los desfases de tiempo que traban los sliders externos
    _audioHandler.playerInstance.onPositionChanged.listen((p) {
      if (mounted) {
        setState(() {
          _position = p.inMilliseconds > _duration.inMilliseconds
              ? _duration
              : p;
        });
      }
    });

    _audioHandler.playerInstance.onPlayerStateChanged.listen((state) {
      if (mounted) {
        setState(() => _isPlaying = state == PlayerState.playing);
      }
    });

    _audioHandler.playerInstance.onPlayerComplete.listen(
      (event) => _nextSongWithShuffle(),
    );

    _audioHandler.onNextRequested = () => _nextSongWithShuffle();
    _audioHandler.onPrevRequested = () => _prevSongWithShuffle();
  }

  Future<void> _loadSavedPlaylist() async {
    final prefs = await SharedPreferences.getInstance();
    final savedList = prefs.getStringList('saved_playlist') ?? [];
    if (savedList.isNotEmpty) {
      setState(() {
        _playlist = savedList;
        _currentIndex = 0;
      });
    }
  }

  Future<void> _savePlaylist() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setStringList('saved_playlist', _playlist);
  }

  void _mostrarMenuCarpetas(BuildContext context) {
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.grey[900],
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.only(
          topLeft: Radius.circular(20),
          topRight: Radius.circular(20),
        ),
      ),
      builder: (context) {
        return SafeArea(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const Padding(
                padding: EdgeInsets.all(16.0),
                child: Text(
                  "Seleccionar origen de música",
                  style: TextStyle(
                    fontWeight: FontWeight.bold,
                    fontSize: 16,
                    color: Colors.teal,
                  ),
                ),
              ),
              ListTile(
                leading: const Icon(Icons.download, color: Colors.teal),
                title: const Text("Carpeta Descargas (Downloads)"),
                subtitle: const Text(
                  "Escanear música de la carpeta principal del sistema",
                ),
                onTap: () {
                  Navigator.pop(context);
                  _openDownloadsDirectly();
                },
              ),
              ListTile(
                leading: const Icon(Icons.folder_copy, color: Colors.teal),
                title: const Text("Elegir otra carpeta"),
                subtitle: const Text(
                  "Abrir el explorador para buscar otras subcarpetas",
                ),
                onTap: () {
                  Navigator.pop(context);
                  _pickFolder();
                },
              ),
              const SizedBox(height: 10),
            ],
          ),
        );
      },
    );
  }

  Future<void> _pickFolder() async {
    try {
      if (await Permission.audio.request().isGranted ||
          await Permission.storage.request().isGranted) {
        String? directoryPath = await FilePicker.platform.getDirectoryPath();
        if (directoryPath == null) return;
        _scanDirectory(directoryPath);
      }
    } catch (e) {
      debugPrint("Error al seleccionar carpeta: $e");
    }
  }

  Future<void> _openDownloadsDirectly() async {
    try {
      var status = await Permission.manageExternalStorage.status;
      if (!status.isGranted) {
        status = await Permission.manageExternalStorage.request();
      }

      if (status.isGranted) {
        _scanDirectory('/storage/emulated/0/Download');
      } else {
        if (await Permission.manageExternalStorage.isPermanentlyDenied) {
          openAppSettings();
        }
      }
    } catch (e) {
      debugPrint("Error en acceso directo a Descargas: $e");
    }
  }

  Future<void> _scanDirectory(String path) async {
    final dir = Directory(path);
    final List<String> nuevosMp3 = [];

    await for (var entity in dir.list(recursive: false, followLinks: false)) {
      if (entity is File && p.extension(entity.path).toLowerCase() == '.mp3') {
        if (!_playlist.contains(entity.path)) {
          nuevosMp3.add(entity.path);
        }
      }
    }

    if (nuevosMp3.isNotEmpty) {
      nuevosMp3.sort((a, b) => p.basename(a).compareTo(b));

      setState(() {
        _playlist.addAll(nuevosMp3);
        if (_currentIndex == -1) {
          _currentIndex = 0;
        }
      });

      await _savePlaylist();

      if (_isShuffle) {
        _rebuildShuffleIndices();
      }

      if (!_isPlaying && _currentIndex == _playlist.indexOf(nuevosMp3.first)) {
        await _playCurrent();
      }

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(
              'Se añadieron ${nuevosMp3.length} canciones a la lista.',
            ),
            backgroundColor: Colors.teal,
          ),
        );
      }
    } else {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text(
              'No se encontraron canciones nuevas en esta carpeta.',
            ),
            backgroundColor: Colors.orange,
          ),
        );
      }
    }
  }

  Future<void> _eliminarCancion(int index) async {
    try {
      if (_playlist.isEmpty || index < 0 || index >= _playlist.length) return;

      setState(() {
        if (_currentIndex == index) {
          _playlist.removeAt(index);
          _currentIndex = _playlist.isNotEmpty ? 0 : -1;
          _isPlaying = false;
        } else {
          if (_currentIndex > index) {
            _currentIndex--;
          }
          _playlist.removeAt(index);
        }
      });

      await _savePlaylist();

      if (_isShuffle) {
        _rebuildShuffleIndices();
      }

      if (_playlist.isEmpty) {
        _currentIndex = -1;
      } else if (_currentIndex == index && _playlist.isNotEmpty) {
        await _playCurrent();
      }
    } catch (e) {
      debugPrint("Error al eliminar canción de la playlist: $e");
    }
  }

  Future<void> _clearPlaylist() async {
    await _audioHandler.stop();
    setState(() {
      _playlist.clear();
      _currentIndex = -1;
      _isPlaying = false;
      _isShuffle = false;
      _shuffledIndices.clear();
      _duration = Duration.zero;
      _position = Duration.zero;
    });

    final prefs = await SharedPreferences.getInstance();
    await prefs.remove('saved_playlist');

    if (mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Lista de reproducción vaciada.'),
          backgroundColor: Colors.redAccent,
        ),
      );
    }
  }

  Future<void> _playCurrent() async {
    if (_currentIndex < 0 || _currentIndex >= _playlist.length) return;

    final filePath = _playlist[_currentIndex];
    final file = File(filePath);

    try {
      if (!await file.exists() || await file.length() == 0) {
        _handlePlaybackError("Archivo vacío o dañado.");
        return;
      }

      await _audioHandler.playLocalFile(filePath);
    } catch (e) {
      _handlePlaybackError("Error de decodificación de Android.");
    }
  }

  void _handlePlaybackError(String motivo) {
    if (!mounted) return;
    final nombreCancion = p.basename(_playlist[_currentIndex]);

    ScaffoldMessenger.of(context).clearSnackBars();
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('Saltando "$nombreCancion": $motivo'),
        duration: const Duration(seconds: 2),
        backgroundColor: Colors.amber.shade900,
      ),
    );

    Future.delayed(const Duration(milliseconds: 500), () {
      _nextSongWithShuffle();
    });
  }

  void _togglePlay() async {
    try {
      if (_playlist.isEmpty) {
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('La lista de reproducción está vacía.'),
            ),
          );
        }
        return;
      }

      if (_isPlaying) {
        _audioHandler.pause();
      } else {
        // CORRECCIÓN CLAVE: Si el índice es válido pero la posición es CERO (la app se acaba de abrir),
        // significa que el reproductor está vacío. Forzamos la carga física del archivo.
        if (_currentIndex >= 0 && _currentIndex < _playlist.length && _position != Duration.zero) {
          _audioHandler.play();
        } else {
          // Si el índice era -1, inválido, o la app recién se abre con posición en cero,
          // aseguramos que apunte a la primera canción y la inyectamos en el reproductor.
          setState(() {
            if (_currentIndex < 0 || _currentIndex >= _playlist.length) {
              _currentIndex = 0;
            }
          });
          await _playCurrent(); 
        }
      }
    } catch (e) {
      debugPrint("Error en el botón de reproducción: $e");
    }
  }

  void _toggleShuffle() {
    setState(() {
      _isShuffle = !_isShuffle;
      if (_isShuffle) {
        _rebuildShuffleIndices();
      }
    });
  }

  void _rebuildShuffleIndices() {
    _shuffledIndices = List.generate(_playlist.length, (i) => i);
    _shuffledIndices.shuffle();
    if (_currentIndex != -1) {
      _shuffledIndices.remove(_currentIndex);
      _shuffledIndices.insert(0, _currentIndex);
    }
  }

  void _nextSongWithShuffle() {
    if (_playlist.isEmpty) return;
    if (_isShuffle && _shuffledIndices.isNotEmpty) {
      int currentShufflePos = _shuffledIndices.indexOf(_currentIndex);
      int nextShufflePos = (currentShufflePos + 1) % _shuffledIndices.length;
      setState(() {
        _currentIndex = _shuffledIndices[nextShufflePos];
      });
    } else {
      setState(() {
        _currentIndex = (_currentIndex + 1) % _playlist.length;
      });
    }
    _playCurrent();
  }
