  void _prevSongWithShuffle() {
    if (_playlist.isEmpty) return;
    if (_isShuffle && _shuffledIndices.isNotEmpty) {
      int currentShufflePos = _shuffledIndices.indexOf(_currentIndex);
      int prevShufflePos =
          (currentShufflePos - 1 + _shuffledIndices.length) %
          _shuffledIndices.length;
      setState(() {
        _currentIndex = _shuffledIndices[prevShufflePos];
      });
    } else {
      setState(() {
        _currentIndex =
            (_currentIndex - 1 + _playlist.length) % _playlist.length;
      });
    }
    _playCurrent();
  }

  String _formatDuration(Duration duration) {
    String twoDigits(int n) => n.toString().padLeft(2, '0');
    final minutes = twoDigits(duration.inMinutes.remainder(60));
    final seconds = twoDigits(duration.inSeconds.remainder(60));
    return "$minutes:$seconds";
  }

