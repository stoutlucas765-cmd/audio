  String _formatDuration(Duration duration) {
    String twoDigits(int n) => n.toString().padLeft(2, '0');
    final minutes = twoDigits(duration.inMinutes.remainder(60));
    final seconds = twoDigits(duration.inSeconds.remainder(60));
    return "$minutes:$seconds";
  }

  void _toggleEqualizer() {
    setState(() {
      _showEqualizer = !_showEqualizer;
    });

    if (_showEqualizer) {
       final int? sessionId = _audioHandler.playerInstance.androidAudioSessionId;
      _equalizerController.init(audioSessionId: sessionId ?? 0);
      // Apply current sliders when opening.
      _equalizerController.setGains(
        bass: _bassDb,
        mid: _midDb,
        treble: _trebleDb,
      );
    }
  }

  Future<void> _applyEqualizerGains() async {
    await _equalizerController.setGains(
      bass: _bassDb,
      mid: _midDb,
      treble: _trebleDb,
    );
  }

  Widget _buildBandSlider({
    required String label,
    required double valueDb,
    required ValueChanged<double> onChanged,
  }) {
    return Column(
      children: [
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Text(
              label,
              style: const TextStyle(
                fontSize: 12,
                color: Colors.grey,
                fontWeight: FontWeight.bold,
              ),
            ),
            Text(
              '${valueDb.toStringAsFixed(0)} dB',
              style: const TextStyle(fontSize: 12, color: Colors.grey),
            ),
          ],
        ),
        Slider(
          activeColor: Colors.teal,
          inactiveColor: Colors.grey,
          min: -10,
          max: 10,
          value: valueDb.clamp(-10, 10),
          onChanged: (v) => onChanged(v),
        ),
      ],
    );
  }

  @override
  Widget build(BuildContext context) {
    final String currentTrackName =
        (_currentIndex != -1 && _playlist.isNotEmpty)
        ? p.basename(_playlist[_currentIndex])
        : "Ninguna canción seleccionada";

    final List<String> filteredPlaylist = _getVisiblePlaylist();

    return Scaffold(
      appBar: AppBar(
        title: _isSearching
            ? TextField(
                controller: _searchController,
                autofocus: true,
                decoration: const InputDecoration(
                  hintText: "Buscar canción...",
                  border: InputBorder.none,
                  hintStyle: TextStyle(color: Colors.grey),
                ),
                style: const TextStyle(color: Colors.white, fontSize: 16),
                onChanged: (value) {
                  setState(() {
                    _searchQuery = value;
                  });
                },
              )
            : const Text(
                'Luks-Player',
                style: TextStyle(
                  fontWeight: FontWeight.bold,
                  color: Colors.teal,
                ),
              ),
        backgroundColor: Colors.transparent,
        elevation: 0,
        leading: PopupMenuButton(
          icon: const Icon(Icons.menu, color: Colors.teal),
          onSelected: (value) async {
            if (value == 'agregar') {
              _mostrarMenuCarpetas(context);
            } else if (value == 'limpiar') {
              _mostrarDialogoConfirmacion(context);
            } else if (value == 'cerrar') {
              await _audioHandler.stop();
              if (Platform.isAndroid) {
                SystemChannels.platform.invokeMethod('SystemNavigator.pop');
              } else {
                exit(0);
              }
            }
          },
          itemBuilder: (BuildContext context) => <PopupMenuEntry>[
            const PopupMenuItem(
              value: 'agregar',
              child: Row(
                children: [
                  Icon(Icons.create_new_folder, color: Colors.teal, size: 20),
                  SizedBox(width: 10),
                  Text('Añadir Carpeta'),
                ],
              ),
            ),
            if (_playlist.isNotEmpty)
              const PopupMenuItem(
                value: 'limpiar',
                child: Row(
                  children: [
                    Icon(Icons.delete_sweep, color: Colors.redAccent, size: 20),
                    SizedBox(width: 10),
                    Text('Vaciar lista'),
                  ],
                ),
              ),
            const PopupMenuDivider(),
            const PopupMenuItem(
              value: 'cerrar',
              child: Row(
                children: [
                  Icon(
                    Icons.power_settings_new,
                    color: Colors.orangeAccent,
                    size: 20,
                  ),
                  SizedBox(width: 10),
                  Text('Cerrar'),
                ],
              ),
            ),
          ],
        ),
        actions: [
          if (_playlist.isNotEmpty)
            IconButton(
              icon: Icon(
                _isSearching ? Icons.close : Icons.search,
                color: Colors.teal,
              ),
              onPressed: () {
                setState(() {
                  if (_isSearching) {
                    _isSearching = false;
                    _searchController.clear();
                    _searchQuery = "";
                  } else {
                    _isSearching = true;
                  }
                });
              },
            ),
          IconButton(
            tooltip: 'Ecualizador',
            icon: Icon(
              _showEqualizer ? Icons.tune : Icons.tune_outlined,
              color: _showEqualizer ? Colors.tealAccent : Colors.teal,
            ),
            onPressed: () {
              _toggleEqualizer();
            },
          ),
        ],
      ),
      body: Column(
        children: [
          Expanded(
            child: filteredPlaylist.isEmpty
                ? const Center(
                    child: Padding(
                      padding: EdgeInsets.all(24.0),
                      child: Text(
                        'No hay canciones.',
                        style: TextStyle(color: Colors.grey),
                      ),
                    ),
                  )
                : ListView.builder(
                    controller: _scrollController,
                    itemExtent: 48.0,
                    itemCount: filteredPlaylist.length,
                    itemBuilder: (context, index) {
                      final String songPath = filteredPlaylist[index];
                      final String songName = p
                          .basename(songPath)
                          .replaceAll('.mp3', '');
                      final int originalIndex = _playlist.indexOf(songPath);
                      final bool isSelected = _currentIndex == originalIndex;

                      _songKeys.putIfAbsent(songPath, () => GlobalKey());

                      return Dismissible(
                        key: Key(songPath),
                        direction: DismissDirection.horizontal,
                        onDismissed: (_) => _eliminarCancion(originalIndex),
                        child: Container(
                          key: _songKeys[songPath],
                          child: ListTile(
                            dense: true,
                            visualDensity: VisualDensity.compact,
                            leading: Icon(
                              Icons.music_note,
                              color: isSelected ? Colors.teal : Colors.grey,
                              size: 20,
                            ),
                            title: Text(
                              songName,
                              style: TextStyle(
                                color: isSelected ? Colors.teal : Colors.white,
                                fontWeight: isSelected
                                    ? FontWeight.bold
                                    : FontWeight.normal,
                                fontSize: 14,
                              ),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                            ),
                            onTap: () async {
                              _currentIndex = originalIndex;
                              await _playCurrent();
                            },
                          ),
                        ),
                      );
                    },
                  ),
          ),
          if (_showEqualizer)
            Container(
              padding: const EdgeInsets.only(
                top: 12,
                bottom: 12,
                left: 16,
                right: 16,
              ),
              decoration: BoxDecoration(
                color: Colors.black38,
                borderRadius: const BorderRadius.only(
                  topLeft: Radius.circular(20),
                  topRight: Radius.circular(20),
                ),
                border: Border(
                  top: BorderSide(color: Colors.white.withAlpha(13)),
                ),
              ),
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  const Text(
                    'Ecualizador',
                    style: TextStyle(
                      fontSize: 14,
                      fontWeight: FontWeight.bold,
                      color: Colors.tealAccent,
                    ),
                  ),
                  const SizedBox(height: 8),
                  _buildBandSlider(
                    label: 'BASS',
                    valueDb: _bassDb,
                    onChanged: (v) {
                      setState(() => _bassDb = v);
                      _applyEqualizerGains();
                    },
                  ),
                  _buildBandSlider(
                    label: 'MID',
                    valueDb: _midDb,
                    onChanged: (v) {
                      setState(() => _midDb = v);
                      _applyEqualizerGains();
                    },
                  ),
                  _buildBandSlider(
                    label: 'TREBLE',
                    valueDb: _trebleDb,
                    onChanged: (v) {
                      setState(() => _trebleDb = v);
                      _applyEqualizerGains();
                    },
                  ),
                  const SizedBox(height: 6),
                  TextButton(
                    onPressed: () {
                      setState(() {
                        _bassDb = 0.0;
                        _midDb = 0.0;
                        _trebleDb = 0.0;
                      });
                      _applyEqualizerGains();
                    },
                    child: const Text(
                      'Reset',
                      style: TextStyle(color: Colors.tealAccent),
                    ),
                  ),
                ],
              ),
            ),
          Container(
            padding: const EdgeInsets.only(
              bottom: 24,
              top: 12,
              left: 16,
              right: 16,
            ),
            decoration: BoxDecoration(
              color: Colors.black38,
              borderRadius: const BorderRadius.only(
                topLeft: Radius.circular(20),
                topRight: Radius.circular(20),
              ),
              border: Border(
                top: BorderSide(color: Colors.white.withAlpha(13)),
              ),
            ),
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                Text(
                  currentTrackName,
                  maxLines: 1,
                  overflow: TextOverflow.ellipsis,
                  style: const TextStyle(
                    fontSize: 15,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                const SizedBox(height: 4),
                Row(
                  children: [
                    Text(
                      _formatDuration(_position),
                      style: const TextStyle(fontSize: 12, color: Colors.grey),
                    ),
                    Expanded(
                      child: Slider(
                        activeColor: Colors.teal,
                        inactiveColor: Colors.grey,
                        value: _position.inMilliseconds.toDouble().clamp(
                          0.0,
                          _duration.inMilliseconds.toDouble() > 0
                              ? _duration.inMilliseconds.toDouble()
                              : 1.0,
                        ),
                        max: _duration.inMilliseconds.toDouble() > 0
                            ? _duration.inMilliseconds.toDouble()
                            : 1.0,
                        onChanged: (value) {
                          final int nuevaPos = value.toInt();
                          if (nuevaPos >= 0 &&
                              nuevaPos <= _duration.inMilliseconds) {
                            setState(() {
                              _position = Duration(milliseconds: nuevaPos);
                            });
                            _audioHandler.seek(
                              Duration(milliseconds: nuevaPos),
                            );
                          }
                        },
                      ),
                    ),
                    Text(
                      _formatDuration(_duration),
                      style: const TextStyle(fontSize: 12, color: Colors.grey),
                    ),
                  ],
                ),
                Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    IconButton(
                      icon: Icon(
                        _isShuffle
                            ? Icons.shuffle_on_rounded
                            : Icons.shuffle_rounded,
                        size: 26,
                      ),
                      color: _isShuffle ? Colors.tealAccent : Colors.grey,
                      onPressed: _playlist.isEmpty ? null : _toggleShuffle,
                    ),
                    const SizedBox(width: 16),
                    IconButton(
                      icon: const Icon(Icons.skip_previous_rounded, size: 40),
                      onPressed: _playlist.isEmpty
                          ? null
                          : _prevSongWithShuffle,
                    ),
                    const SizedBox(width: 20),
                    IconButton(
                      icon: Icon(
                        _isPlaying
                            ? Icons.pause_circle_filled_rounded
                            : Icons.play_circle_filled_rounded,
                        size: 64,
                      ),
                      color: Colors.tealAccent,
                      onPressed: _playlist.isEmpty ? null : _togglePlay,
                    ),
                    const SizedBox(width: 20),
                    IconButton(
                      icon: const Icon(Icons.skip_next_rounded, size: 40),
                      onPressed: _playlist.isEmpty
                          ? null
                          : _nextSongWithShuffle,
                    ),
                    const SizedBox(width: 42),
                  ],
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}
