  Future<void> _pickFolder() async {
    try {
      if (await Permission.audio.request().isGranted ||
          await Permission.storage.request().isGranted) {
        final String? directoryPath = await FilePicker.platform
            .getDirectoryPath();
        if (directoryPath == null) return;
        _scanDirectory(directoryPath);
      }
    } catch (e) {
      debugPrint("Error carpeta: $e");
    }
  }

  Future<void> _openDownloadsDirectly() async {
    try {
      var status = await Permission.manageExternalStorage.status;
      if (!status.isGranted) {
        status = await Permission.manageExternalStorage.request();
      }

      if (status.isGranted) {
        _scanDirectory('/storage/emulated/0/Download');
      } else {
        if (await Permission.manageExternalStorage.isPermanentlyDenied) {
          openAppSettings();
        }
      }
    } catch (e) {
      debugPrint("Error downloads: $e");
    }
  }

  Future<void> _scanDirectory(String path) async {
    final dir = Directory(path);
    final List<String> nuevosMp3 = <String>[];

    await for (final entity in dir.list(recursive: false, followLinks: false)) {
      if (entity is File && p.extension(entity.path).toLowerCase() == '.mp3') {
        if (!_playlist.contains(entity.path)) {
          nuevosMp3.add(entity.path);
        }
      }
    }

    if (nuevosMp3.isNotEmpty) {
      nuevosMp3.sort((a, b) => p.basename(a).compareTo(b));

      setState(() {
        _playlist.addAll(nuevosMp3);
        if (_currentIndex == -1) _currentIndex = 0;
      });

      await _savePlaylist();
      if (_isShuffle) {
        _rebuildShuffleIndices();
      }

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(
              'Se añadieron ${nuevosMp3.length} canciones a la lista.',
            ),
            backgroundColor: Colors.teal,
          ),
        );
      }

      if (!_isPlaying && _currentIndex == _playlist.indexOf(nuevosMp3.first)) {
        await _playCurrent();
      }
    } else {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text(
              'No se encontraron canciones nuevas en esta carpeta.',
            ),
            backgroundColor: Colors.orange,
          ),
        );
      }
    }
  }

  Future<void> _eliminarCancion(int index) async {
    try {
      if (_playlist.isEmpty || index < 0 || index >= _playlist.length) return;

      final bool borroLaCancionActual = (_currentIndex == index);

      String? proximaCancionPath;
      if (borroLaCancionActual && _playlist.length > 1) {
        if (_isShuffle && _shuffledIndices.isNotEmpty) {
          final int currentShufflePos = _shuffledIndices.indexOf(_currentIndex);
          final int nextShufflePos =
              (currentShufflePos + 1) % _shuffledIndices.length;
          proximaCancionPath = _playlist[_shuffledIndices[nextShufflePos]];
        } else {
          final int siguienteIndiceFisico = (index + 1) % _playlist.length;
          proximaCancionPath = _playlist[siguienteIndiceFisico];
        }
      }

      setState(() {
        if (borroLaCancionActual) {
          _playlist.removeAt(index);
          _isPlaying = false;
        } else {
          if (_currentIndex > index) _currentIndex--;
          _playlist.removeAt(index);
        }
      });

      await _savePlaylist();

      if (_isShuffle) {
        _rebuildShuffleIndices();
      }

      if (borroLaCancionActual && _playlist.isNotEmpty) {
        if (proximaCancionPath != null &&
            _playlist.contains(proximaCancionPath)) {
          _currentIndex = _playlist.indexOf(proximaCancionPath);
        } else {
          _currentIndex = _playlist.isNotEmpty ? 0 : -1;
        }

        if (_currentIndex != -1) {
          await _playCurrent();
        }
      } else if (_playlist.isEmpty) {
        _currentIndex = -1;
        await _audioHandler.stop();
      }
    } catch (e) {
      debugPrint("Error eliminar canción con shuffle: $e");
    }
  }

  Future<void> _clearPlaylist() async {
    await _audioHandler.stop();
    setState(() {
      _playlist.clear();
      _currentIndex = -1;
      _isPlaying = false;
      _isShuffle = false;
      _shuffledIndices.clear();
      _duration = Duration.zero;
      _position = Duration.zero;
    });

    final prefs = await SharedPreferences.getInstance();
    await prefs.remove('saved_playlist');
  }

  void _togglePlay() async {
    try {
      if (_playlist.isEmpty) return;

      if (_isPlaying) {
        await _audioHandler.pause();
        return;
      }

      if (_currentIndex >= 0 && _currentIndex < _playlist.length) {
        if (_position != Duration.zero) {
          await _audioHandler.play();
        } else {
          await _playCurrent();
        }
      }
    } catch (e) {
      debugPrint("Error toggle: $e");
    }
  }

  void _toggleShuffle() {
    setState(() {
      _isShuffle = !_isShuffle;
      if (_isShuffle) {
        _rebuildShuffleIndices();
      }
    });
  }

  void _rebuildShuffleIndices() {
    _shuffledIndices = List.generate(_playlist.length, (i) => i);
    _shuffledIndices.shuffle();

    if (_currentIndex != -1) {
      _shuffledIndices.remove(_currentIndex);
      _shuffledIndices.insert(0, _currentIndex);
    }
  }

  void _nextSongWithShuffle() {
    if (_playlist.isEmpty) return;

    setState(() {
      if (_isShuffle && _shuffledIndices.isNotEmpty) {
        final int currentShufflePos = _shuffledIndices.indexOf(_currentIndex);
        final int nextShufflePos =
            (currentShufflePos + 1) % _shuffledIndices.length;
        _currentIndex = _shuffledIndices[nextShufflePos];
      } else {
        _currentIndex = (_currentIndex + 1) % _playlist.length;
      }
    });

    _audioHandler.actualizarColaSistema(_playlist, _currentIndex);
    _playCurrent();

    final String currentPath = _playlist[_currentIndex];
    final int visualIndex = _isSearching
        ? _getVisiblePlaylist().indexOf(currentPath)
        : _currentIndex;

    if (visualIndex != -1) {
      _scrollToCurrentSong(visualIndex);
    }
  }

  void _prevSongWithShuffle() {
    if (_playlist.isEmpty) return;

    setState(() {
      if (_isShuffle && _shuffledIndices.isNotEmpty) {
        final int currentShufflePos = _shuffledIndices.indexOf(_currentIndex);
        final int prevShufflePos =
            (currentShufflePos - 1 + _shuffledIndices.length) %
            _shuffledIndices.length;
        _currentIndex = _shuffledIndices[prevShufflePos];
      } else {
        _currentIndex =
            (_currentIndex - 1 + _playlist.length) % _playlist.length;
      }
    });

    _audioHandler.actualizarColaSistema(_playlist, _currentIndex);
    _playCurrent();

    final String currentPath = _playlist[_currentIndex];
    final int visualIndex = _isSearching
        ? _getVisiblePlaylist().indexOf(currentPath)
        : _currentIndex;

    if (visualIndex != -1) {
      _scrollToCurrentSong(visualIndex);
    }
  }

