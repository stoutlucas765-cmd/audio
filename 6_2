// ---------------- Equalizer (3 bands) ----------------
class EqualizerGains {
  final double bass;
  final double mid;
  final double treble;

  const EqualizerGains({
    required this.bass,
    required this.mid,
    required this.treble,
  });

  static const zero = EqualizerGains(bass: 0, mid: 0, treble: 0);
}

/// Controller para ecualizador nativo (Android) vía MethodChannel.
class EqualizerController {
  EqualizerController();

  final MethodChannel _methodChannel =
      const MethodChannel('reproductor_mp3/equalizer');

  bool _initialized = false;
  bool _isSupported = false;

  /// Inicia el ecualizador con un audioSessionId.
  Future<void> init({required int audioSessionId}) async {
    if (_initialized) return;

    try {
      final bool ok =
          (await _methodChannel.invokeMethod<bool>('init', {
                'audioSessionId': audioSessionId,
              })) ??
              false;
      _isSupported = ok;
    } catch (_) {
      _isSupported = false;
    } finally {
      _initialized = true;
    }
  }

  Future<void> setGains({
    required double bass,
    required double mid,
    required double treble,
  }) async {
    if (!_initialized || !_isSupported) return;

    try {
      await _methodChannel.invokeMethod('setGains', {
        'bass': bass,
        'mid': mid,
        'treble': treble,
      });
    } catch (_) {
      // best-effort
    }
  }

  Future<void> release() async {
    if (!_initialized) return;
    try {
      await _methodChannel.invokeMethod('release');
    } catch (_) {
      // best-effort
    } finally {
      _initialized = false;
      _isSupported = false;
    }
  }
}

final EqualizerController _equalizerController = EqualizerController();

