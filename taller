class ConfigPage extends StatefulWidget {

  final Box<Vehiculo> vehiculosBox;
  final Box<Historial> historialBox;
  final Box<EmpresaPresupuesto> empresaPresupuestoBox;

  const ConfigPage({
    super.key,
    required this.vehiculosBox,
    required this.historialBox,
    required this.empresaPresupuestoBox,
  });

  @override
  State<ConfigPage> createState() => _ConfigPageState();
}

class _ConfigPageState extends State<ConfigPage> {
  bool _busy = false;



  Future<String> _defaultFilePath() async {
    final dir = await getApplicationDocumentsDirectory();
    return '${dir.path}/taller_backup.txt';
  }

  Future<void> _importFromFile() async {
    setState(() => _busy = true);
    try {
      final filePath = await _defaultFilePath();
      final f = File(filePath);
      if (!await f.exists()) {
        if (!mounted) return;
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('No se encontró el backup taller_backup.txt')),
        );
        return;
      }

      final raw = await f.readAsString();

      final data = _parseBackup(raw);
      if (data == null) {
        if (!mounted) return;
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('Backup inválido o corrupto')),
        );
        return;
      }

      // Borrar primero
      await widget.vehiculosBox.clear();
      await widget.historialBox.clear();

      final vehiculos = (data['vehiculos'] as List?) ?? [];
      for (final item in vehiculos) {
        if (item is! Map) continue;
        final v = item.cast<String, dynamic>();
        final patente = (v['patente'] ?? '').toString();
        if (patente.isEmpty) continue;

        final nueva = Vehiculo(
          patente: patente,
          marca: (v['marca'] ?? '').toString(),
          modelo: (v['modelo'] ?? '').toString(),
          anio: (v['anio'] as num?)?.toInt() ?? int.tryParse((v['anio'] ?? '').toString()) ?? 0,
          kilometraje: (v['kilometraje'] as num?)?.toInt() ?? int.tryParse((v['kilometraje'] ?? '').toString()) ?? 0,
          duenio: (v['duenio'] ?? '').toString(),
          telefono: (v['telefono'] ?? '').toString(),
          valorManoDeObra:
              (v['valorManoDeObra'] as num?)?.toDouble() ?? double.tryParse((v['valorManoDeObra'] ?? '').toString()) ?? 0.0,
          notas: (v['notas'] ?? '').toString(),
        );

        widget.vehiculosBox.put(patente, nueva);
      }

      final historial = (data['historial'] as List?) ?? [];
      for (final item in historial) {
        if (item is! Map) continue;
        final h = item.cast<String, dynamic>();

        final fechaStr = (h['fechaHora'] ?? '').toString();
        final fecha = DateTime.tryParse(fechaStr);
        if (fecha == null) continue;

        final tipoIndex = (h['tipoAccionIndex'] as num?)?.toInt() ??
            int.tryParse((h['tipoAccionIndex'] ?? '').toString()) ??
            0;
        final tipo = _tipoAccionFromIndex(tipoIndex);

        widget.historialBox.add(
          Historial(
            fechaHora: fecha,
            patente: (h['patente'] ?? '').toString(),
            tipoAccion: tipo,
            detalleTexto: (h['detalleTexto'] ?? '').toString(),
          ),
        );
      }

      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Backup restaurado correctamente')),
      );
      setState(() {});
    } finally {
      if (mounted) setState(() => _busy = false);
    }
  }

  Map<String, dynamic>? _parseBackup(String raw) {
    // El export usa data.toString(), no JSON real. Intentamos decode JSON y fallback de parse legacy.
    try {
      final decoded = _tryJsonDecode(raw);
      if (decoded is Map<String, dynamic>) return decoded;
    } catch (_) {}

    try {
      return _legacyParseMap(raw);
    } catch (_) {
      return null;
    }
  }

  dynamic _tryJsonDecode(String raw) {
    try {
      return jsonDecode(raw);
    } catch (_) {
      return null;
    }
  }

  Map<String, dynamic>? _legacyParseMap(String raw) {
    var s = raw.trim();
    if (s.isEmpty) return null;

    s = s.replaceAllMapped(RegExp(r"\bvehiculos\b"), (_) => '"vehiculos"');
    s = s.replaceAllMapped(RegExp(r"\bhistorial\b"), (_) => '"historial"');
    s = s.replaceAllMapped(RegExp(r"\bpatente\b"), (_) => '"patente"');
    s = s.replaceAllMapped(RegExp(r"\bmarca\b"), (_) => '"marca"');
    s = s.replaceAllMapped(RegExp(r"\bmodelo\b"), (_) => '"modelo"');
    s = s.replaceAllMapped(RegExp(r"\banio\b"), (_) => '"anio"');
    s = s.replaceAllMapped(RegExp(r"\bkilometraje\b"), (_) => '"kilometraje"');
    s = s.replaceAllMapped(RegExp(r"\bduenio\b"), (_) => '"duenio"');
    s = s.replaceAllMapped(RegExp(r"\btelefono\b"), (_) => '"telefono"');
    s = s.replaceAllMapped(RegExp(r"\bvalorManoDeObra\b"), (_) => '"valorManoDeObra"');
    s = s.replaceAllMapped(RegExp(r"\bnotas\b"), (_) => '"notas"');

    s = s.replaceAllMapped(RegExp(r"\bfechaHora\b"), (_) => '"fechaHora"');
    s = s.replaceAllMapped(RegExp(r"\btipoAccionIndex\b"), (_) => '"tipoAccionIndex"');
    s = s.replaceAllMapped(RegExp(r"\bdetalleTexto\b"), (_) => '"detalleTexto"');

    try {
      final decoded = jsonDecode(s);
      if (decoded is Map<String, dynamic>) return decoded;
      return null;
    } catch (_) {
      return null;
    }
  }

  TipoAccion _tipoAccionFromIndex(int index) {
    for (final v in TipoAccion.values) {
      if (v.index == index) return v;
    }
    return TipoAccion.creacion;
  }

  Future<void> _exportToFile() async {
    setState(() => _busy = true);
    try {
      final filePath = await _defaultFilePath();

      // Texto JSON simple (backup)
      final data = {
        'vehiculos':
            widget.vehiculosBox.values.map((v) => {
                  'patente': v.patente,
                  'marca': v.marca,
                  'modelo': v.modelo,
                  'anio': v.anio,
                  'kilometraje': v.kilometraje,
                  'duenio': v.duenio,
                  'telefono': v.telefono,
                  'valorManoDeObra': v.valorManoDeObra,
                  'notas': v.notas,
                }).toList(),
        'historial': widget.historialBox.values.map((h) => {
              'fechaHora': h.fechaHora.toIso8601String(),
              'patente': h.patente,
              'tipoAccionIndex': h.tipoAccion.index,
              'detalleTexto': h.detalleTexto,
            }).toList(),
      };

      final jsonStr = data.toString();
      final f = File(filePath);
      await f.writeAsString(jsonStr);

      if (!mounted) return;
      await Share.shareXFiles([XFile(filePath)], text: 'Backup del taller');
    } finally {
      if (mounted) setState(() => _busy = false);
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Configuraciones')),
      body: ListView(
        padding: const EdgeInsets.all(12),
        children: [
          const Text(
            'Backup (backup) local',
            style: TextStyle(fontSize: 16, fontWeight: FontWeight.w600),
          ),
          const SizedBox(height: 16),
          SizedBox(
            width: double.infinity,
            child: ElevatedButton.icon(
              onPressed: _busy ? null : _exportToFile,
              icon: const Icon(Icons.upload_file),
              label: Text(_busy ? 'Exportando...' : 'Exportar backup'),
            ),
          ),
          const SizedBox(height: 12),
          SizedBox(
            width: double.infinity,
            child: ElevatedButton.icon(
              onPressed: _busy ? null : _importFromFile,
              icon: const Icon(Icons.download),
              label: Text(_busy ? 'Importando...' : 'Importar / Restaurar backup'),
            ),
          ),
          const SizedBox(height: 20),
          SizedBox(
            width: double.infinity,
            child: ElevatedButton.icon(
              onPressed: () {
                Navigator.of(context).push(
                  MaterialPageRoute(
                    builder: (_) => EditPresupuestoConfigPage(
                      empresaPresupuestoBox: widget.empresaPresupuestoBox,
                    ),
                  ),
                );
              },
              icon: const Icon(Icons.edit_note),
              label: const Text('Editar presupuesto'),
            ),
          ),
          const SizedBox(height: 12),
          const Text(
            'El backup se restaura desde el mismo archivo (taller_backup.txt).',
          ),
        ],

      ),
    );
  }
}

class PresupuestoPage extends StatefulWidget {
  final Vehiculo? vehiculoSeleccionado;
  final Box<EmpresaPresupuesto> empresaPresupuestoBox;

  const PresupuestoPage({
    super.key,
    required this.vehiculoSeleccionado,
    required this.empresaPresupuestoBox,
  });


  @override
  State<PresupuestoPage> createState() => _PresupuestoPageState();
}

class _PresupuestoPageState extends State<PresupuestoPage> {
  Uint8List? _logo;

  final clienteCtrl = TextEditingController();
  final vehiculoCtrl = TextEditingController();
  final descCtrl = TextEditingController();
  final repuestosCtrl = TextEditingController(text: '0');
  final manoCtrl = TextEditingController(text: '0');

  @override
  void initState() {
    super.initState();
    if (widget.vehiculoSeleccionado != null) {
      vehiculoCtrl.text = widget.vehiculoSeleccionado!.patente;
      // Presupuesto nuevo: arrancar con montos en 0 para que el cliente los edite.
      manoCtrl.text = '0';
      repuestosCtrl.text = '0';
      clienteCtrl.text = widget.vehiculoSeleccionado!.duenio;
      descCtrl.text = widget.vehiculoSeleccionado!.notas;
    }


    _loadEmpresaPresupuesto();
  }


  @override
  void dispose() {
    clienteCtrl.dispose();
    vehiculoCtrl.dispose();
    descCtrl.dispose();
    repuestosCtrl.dispose();
    manoCtrl.dispose();
    super.dispose();
  }

  double _parseMoney(TextEditingController c) {
    final v = c.text.trim().replaceAll(',', '.');
    return double.tryParse(v) ?? 0.0;
  }

  double get _total => _parseMoney(repuestosCtrl) + _parseMoney(manoCtrl);

  Future<void> _loadEmpresaPresupuesto() async {
    final config = widget.empresaPresupuestoBox.values.isNotEmpty ? widget.empresaPresupuestoBox.get(widget.empresaPresupuestoBox.keys.first) : null;
    // Nota: usando la primera key porque guardamos un único registro en la box.
    if (config == null) return;
    setState(() {
      _logo = config.logoBytes;
      clienteCtrl.text = config.nombre;
    });
  }


  Future<void> _generateAndShare() async {
    final repuestos = _parseMoney(repuestosCtrl);
    final mano = _parseMoney(manoCtrl);
    final total = _total;

    final doc = pw.Document();
    final df = DateFormat('dd/MM/yyyy HH:mm');
    final currency = NumberFormat.currency(symbol: r'$ ', decimalDigits: 2);


    pw.Widget logoWidget;
    if (_logo == null) {
      logoWidget = pw.Container(
        width: 120,
        height: 60,
        decoration: pw.BoxDecoration(border: pw.Border.all(color: PdfColors.grey300)),
        child: pw.Center(
          child: pw.Text('LOGO', style: pw.TextStyle(color: PdfColors.grey600)),
        ),
      );
    } else {
      final img = pw.MemoryImage(_logo!);
      logoWidget = pw.Container(
        width: 140,
        height: 70,
        child: pw.Image(img, fit: pw.BoxFit.contain),
      );
    }

    doc.addPage(
      pw.Page(
        pageFormat: PdfPageFormat.a4,
        build: (_) {
          return pw.Padding(
            padding: const pw.EdgeInsets.all(24),
            child: pw.Column(
              crossAxisAlignment: pw.CrossAxisAlignment.start,
              children: [
                        pw.Row(
                          mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
                          crossAxisAlignment: pw.CrossAxisAlignment.start,
                          children: [
                            logoWidget,
                            pw.Column(
                              crossAxisAlignment: pw.CrossAxisAlignment.end,
                              children: [
                                pw.Text(
                                  'PRESUPUESTO',
                                  style: pw.TextStyle(fontSize: 22, fontWeight: pw.FontWeight.bold),
                                ),
                                pw.SizedBox(height: 8),
                                pw.Text(widget.empresaPresupuestoBox.values.isNotEmpty ? widget.empresaPresupuestoBox.get(widget.empresaPresupuestoBox.keys.first)!.nombre : '-'),
                                pw.Text(widget.empresaPresupuestoBox.values.isNotEmpty ? widget.empresaPresupuestoBox.get(widget.empresaPresupuestoBox.keys.first)!.telefono : '-'),
                                pw.SizedBox(height: 6),
                                pw.Text(widget.empresaPresupuestoBox.values.isNotEmpty ? widget.empresaPresupuestoBox.get(widget.empresaPresupuestoBox.keys.first)!.direccion : '-'),
                                pw.Text(widget.empresaPresupuestoBox.values.isNotEmpty ? widget.empresaPresupuestoBox.get(widget.empresaPresupuestoBox.keys.first)!.email : '-'),

                                pw.SizedBox(height: 8),
                                pw.Text(df.format(DateTime.now())),

                              ],
                            ),
                          ],
                        ),
                        pw.SizedBox(height: 22),

                _sectionTitle('Datos del Cliente'),
                pw.SizedBox(height: 8),
                pw.Text('Nombre: ${clienteCtrl.text.trim().isEmpty ? '-' : clienteCtrl.text.trim()}'),
                pw.Text('Vehículo: ${vehiculoCtrl.text.trim().isEmpty ? '-' : vehiculoCtrl.text.trim()}'),
                pw.SizedBox(height: 16),
                _sectionTitle('Descripción del Trabajo'),
                pw.SizedBox(height: 8),
                pw.Text(descCtrl.text.trim().isEmpty ? '-' : descCtrl.text.trim()),
                pw.SizedBox(height: 18),
                _sectionTitle('Costos'),
                pw.SizedBox(height: 10),
                pw.Table(
                  border: pw.TableBorder.all(color: PdfColors.grey300),
                  columnWidths: const {
                    0: pw.FlexColumnWidth(1),
                    1: pw.FlexColumnWidth(1),
                  },
                  children: [
                    _tableRow('Costo de Repuestos', currency.format(repuestos)),
                    _tableRow('Costo de Mano de Obra', currency.format(mano)),
                    _tableRow('Total', currency.format(total), isTotal: true),
                  ],
                ),
                pw.SizedBox(height: 18),
                pw.Text(
                  '*Este presupuesto tiene una validez de 7 dias.',
                  style: pw.TextStyle(color: PdfColors.grey600),
                ),
              ],

            ),
          );
        },
      ),
    );

    final dir = await getTemporaryDirectory();
    final file = File('${dir.path}/presupuesto_${DateTime.now().millisecondsSinceEpoch}.pdf');
    await file.writeAsBytes(await doc.save());

    await Share.shareXFiles(
      [XFile(file.path)],
      text: 'Presupuesto generado desde tu taller',
