class _MainPlayerScreenState extends State<MainPlayerScreen> {
  final ScrollController _scrollController = ScrollController();
  final Map<String, GlobalKey> _songKeys = {};
  final TextEditingController _searchController = TextEditingController();

  List<String> _playlist = List<String>.empty(growable: true);
  List<int> _shuffledIndices = List<int>.empty(growable: true);

  int _currentIndex = -1;
  bool _isPlaying = false;
  final AudioPlayer player = AudioPlayer(); // Tu reproductor existente

  // Agrega esta línea para exponerlo:
  AudioPlayer get playerInstance => player;
  bool _isShuffle = false;

  // Se mantiene por compatibilidad con el flujo de carga/visibilidad.
  // (No se utiliza directamente en UI, pero conserva el estado para posibles extensiones.)
  bool _isAudioLoading = false;

  Duration _duration = Duration.zero;
  Duration _position = Duration.zero;

  Timer? _searchDebounce;

  bool _isSearching = false;
  String _searchQuery = "";

  StreamSubscription<Duration?>? _durationSub;
  StreamSubscription<Duration>? _positionSub;
  StreamSubscription<PlayerState>? _playerStateSub;
  StreamSubscription<PlaybackState>? _playbackStateSub;

  @override
  void initState() {
    super.initState();

    _solicitarPermisoBluetooth();
    _initAudioListeners();
    _loadSavedPlaylist();

    _playbackStateSub = _audioHandler.playbackState.listen((state) {
      if (mounted) {
        setState(() {
          _isPlaying = state.playing;
        });
      }
    });
  }

  @override
  void dispose() {
    _searchDebounce?.cancel();

    _durationSub?.cancel();
    _positionSub?.cancel();
    _playerStateSub?.cancel();
    _playbackStateSub?.cancel();

    _searchController.dispose();
    _scrollController.dispose();

    // best-effort cleanup

    super.dispose();
  }

  List<String> _getVisiblePlaylist() {
    if (!_isSearching || _searchQuery.isEmpty) return _playlist;

    final query = _searchQuery.toLowerCase();
    return _playlist
        .where((songPath) => p.basename(songPath).toLowerCase().contains(query))
        .toList();
  }

  void _scrollToCurrentSong(int indexVisual) {
    if (indexVisual < 0 || !_scrollController.hasClients) return;

    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (!_scrollController.hasClients) return;

      final double viewportHeight =
          _scrollController.position.viewportDimension;

      final double songTopOffset = indexVisual * 48.0;
      final double targetOffset = songTopOffset - (viewportHeight / 2) + 24.0;

      final double maxScroll = _scrollController.position.maxScrollExtent;
      _scrollController.jumpTo(targetOffset.clamp(0.0, maxScroll));
    });
  }

  Future<void> _solicitarPermisoBluetooth() async {
    if (await Permission.bluetoothConnect.isDenied) {
      await Permission.bluetoothConnect.request();
    }
  }

  void _initAudioListeners() {
    _audioHandler.playerInstance.androidAudioSessionIdStream.listen(
      (id) async {},
    );

    _durationSub = _audioHandler.playerInstance.durationStream.listen(
      (d) => setState(() => _duration = d ?? Duration.zero),
    );

    _positionSub = _audioHandler.playerInstance.positionStream.listen((p) {
      if (!mounted) return;

      setState(() {
        _position = p.inMilliseconds > _duration.inMilliseconds ? _duration : p;
      });
    });

    _playerStateSub = _audioHandler.playerInstance.playerStateStream.listen((
      state,
    ) {
      if (!mounted) return;

      setState(() {
        _isPlaying = state.playing;
      });

      if (state.playing && _currentIndex != -1 && _playlist.isNotEmpty) {
        final String currentPath = _playlist[_currentIndex];
        final int visualIndex = _isSearching
            ? _getVisiblePlaylist().indexOf(currentPath)
            : _currentIndex;

        _scrollToCurrentSong(visualIndex);
      }

      if (state.processingState == ProcessingState.completed) {
        _nextSongWithShuffle();
      }
    });

    _audioHandler.onNextRequested = () => _nextSongWithShuffle();
    _audioHandler.onPrevRequested = () => _prevSongWithShuffle();
  }

  Future<void> _playCurrent() async {
    if (_currentIndex < 0 || _currentIndex >= _playlist.length) return;

    final String path = _playlist[_currentIndex];
    final int visualIndex = _isSearching
        ? _getVisiblePlaylist().indexOf(path)
        : _currentIndex;

    _scrollToCurrentSong(visualIndex);

    _searchDebounce?.cancel();

    _searchDebounce = Timer(const Duration(milliseconds: 150), () async {
      if (!mounted) return;

      try {
        setState(() => _isAudioLoading = true);

        final file = File(path);

        if (!await file.exists() || await file.length() == 0) {
          debugPrint("Archivo dañado o vacío (0 bytes): $path");
          _nextSongWithShuffle();
          return;
        }

        await _audioHandler.playLocalFile(path);
      } catch (e) {
        debugPrint("Error play current: $e");
        _nextSongWithShuffle();
      } finally {
        if (mounted) {
          Future.delayed(const Duration(milliseconds: 50), () {
            if (mounted) setState(() => _isAudioLoading = false);
          });
        }
      }
    });
  }

  Future<void> _loadSavedPlaylist() async {
    final prefs = await SharedPreferences.getInstance();
    final savedList = prefs.getStringList('saved_playlist') ?? [];
    if (savedList.isNotEmpty) {
      setState(() {
        _playlist = savedList;
        _currentIndex = 0;
      });
    }
  }

  Future<void> _savePlaylist() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setStringList('saved_playlist', _playlist);
  }

