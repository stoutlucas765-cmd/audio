class MyAudioHandler extends BaseAudioHandler with QueueHandler, SeekHandler {
  final AudioPlayer _player = AudioPlayer();
  VoidCallback? onNextRequested;
  VoidCallback? onPrevRequested;

  @override
  Future<void> click([MediaButton button = MediaButton.media]) async {
    switch (button) {
      case MediaButton.media:
        if (playbackState.value.playing) {
          await pause();
        } else {
          await play();
        }
        break;
      case MediaButton.next:
        await skipToNext();
        break;
      case MediaButton.previous:
        await skipToPrevious();
        break;
    }
  }

  MyAudioHandler() {
    playbackState.add(
      PlaybackState(
        controls: const [
          MediaControl.skipToPrevious,
          MediaControl.play,
          MediaControl.skipToNext,
        ],
        systemActions: const {
          MediaAction.seek,
          MediaAction.playPause,
          MediaAction.skipToNext,
          MediaAction.skipToPrevious,
        },
        processingState: AudioProcessingState.idle,
        playing: false,
      ),
    );

    _player.durationStream.listen((d) {
      if (d != null && mediaItem.value != null) {
        mediaItem.add(mediaItem.value!.copyWith(duration: d));
      }
    });

    _player.positionStream.listen((pos) {
      playbackState.add(
        playbackState.value.copyWith(
          updatePosition: pos,
          speed: _player.playing ? 1.0 : 0.0,
        ),
      );
    });

    _player.playerStateStream.listen((state) {
      final playing = state.playing;
      playbackState.add(
        playbackState.value.copyWith(
          playing: playing,
          processingState: const {
            ProcessingState.idle: AudioProcessingState.idle,
            ProcessingState.loading: AudioProcessingState.loading,
            ProcessingState.buffering: AudioProcessingState.buffering,
            ProcessingState.ready: AudioProcessingState.ready,
            ProcessingState.completed: AudioProcessingState.completed,
          }[state.processingState]!,
          controls: [
            MediaControl.skipToPrevious,
            playing ? MediaControl.pause : MediaControl.play,
            MediaControl.skipToNext,
          ],
          systemActions: const {
            MediaAction.seek,
            MediaAction.playPause,
            MediaAction.skipToNext,
            MediaAction.skipToPrevious,
          },
        ),
      );
    });
  }

  @override
  Future<void> play() async => await _player.play();

  @override
  Future<void> pause() async => await _player.pause();

  @override
  Future<void> seek(Duration position) async => await _player.seek(position);

  @override
  Future<void> stop() async => await _player.stop();

  @override
  Future<void> skipToNext() async {
    if (onNextRequested != null) onNextRequested!();
  }

  @override
  Future<void> skipToPrevious() async {
    if (onPrevRequested != null) onPrevRequested!();
  }

  Future<void> playLocalFile(String path) async {
    final title = p.basename(path).replaceAll('.mp3', '');

    try {
      final session = await session_pkg.AudioSession.instance;
      await session.configure(
        const session_pkg.AudioSessionConfiguration(
          avAudioSessionCategory: session_pkg.AVAudioSessionCategory.playback,
          avAudioSessionMode: session_pkg.AVAudioSessionMode.defaultMode,
          androidAudioAttributes: session_pkg.AndroidAudioAttributes(
            contentType: session_pkg.AndroidAudioContentType.music,
            usage: session_pkg.AndroidAudioUsage.media,
          ),
          androidAudioFocusGainType: session_pkg.AndroidAudioFocusGainType.gain,
        ),
      );
      await session.setActive(true);
    } catch (e) {
      debugPrint("Error session: $e");
    }

    mediaItem.add(
      MediaItem(
        id: path,
        album: "Luks-Player",
        title: title,
        artist: "Archivo Local",
        duration: Duration.zero,
      ),
    );

    try {
      // 🔥 CORREGIDO: Usamos la propiedad oficial de just_audio para verificar si está cargando o sonando
      // Si el reproductor está ocupado con el tema anterior, lo frena en seco de forma segura
      if (_player.playing ||
          _player.processingState == ProcessingState.loading ||
          _player.processingState == ProcessingState.buffering) {
        await _player.stop();
      }

      await _player.setAudioSource(
        AudioSource.uri(Uri.file(path)),
        preload: false, // MÁXIMA VELOCIDAD: Evita precargas asíncronas pesadas
      );

      _player.play();

      _player.durationStream.first.then((realDuration) {
        if (realDuration != null && mediaItem.value != null) {
          mediaItem.add(mediaItem.value!.copyWith(duration: realDuration));
        }
      });
    } catch (e) {
      debugPrint("Error play source: $e");
      // Si la carga falla por ráfaga rápida, forzamos una limpieza del reproductor para revivir el hilo
      await _player.stop();
      rethrow;
    }

    playbackState.add(
      playbackState.value.copyWith(
        playing: true,
        processingState: AudioProcessingState.ready,
      ),
    );
  }

  void actualizarColaSistema(List<String> paths, int indiceActual) {
    final List<MediaItem> nuevaCola = [];
    for (int i = 0; i < paths.length; i++) {
      final nombreTrack = p.basename(paths[i]).replaceAll('.mp3', '');
      nuevaCola.add(
        MediaItem(
          id: paths[i],
          title: nombreTrack,
          album: "Luks-Player",
          artist: "Archivo Local",
        ),
      );
    }

    queue.add(nuevaCola);

    if (indiceActual >= 0 && indiceActual < paths.length) {
      // Nos fijamos si el reproductor está sonando actualmente para mantener el ícono correcto
      final bool estaSonando = playbackState.value.playing;

      playbackState.add(
        playbackState.value.copyWith(
          queueIndex: indiceActual,
          // 🔥 REPARACIÓN CRÍTICA: Le volvemos a inyectar los controles físicos al sistema
          // Esto evita que Android deshabilite los botones de Skip al actualizar la lista
          controls: [
            MediaControl.skipToPrevious,
            estaSonando ? MediaControl.pause : MediaControl.play,
            MediaControl.skipToNext,
          ],
          systemActions: const {
            MediaAction.seek,
            MediaAction.playPause,
            MediaAction.skipToNext,
            MediaAction.skipToPrevious,
          },
        ),
      );
    }
  }

  AudioPlayer get playerInstance => _player;
}

